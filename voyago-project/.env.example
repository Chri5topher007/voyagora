# Copy this file to .env and fill in real values before running
# `docker compose up --build`. Never commit the real .env file.

NODE_ENV=production

# --- Database ---
POSTGRES_USER=voyagora
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
POSTGRES_DB=voyagora

# --- Auth ---
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# --- URLs ---
# Public URL of the deployed frontend (used for CORS + Stripe redirect URLs)
FRONTEND_URL=https://your-domain.com
# URL the browser will use to reach the API (baked into the frontend build)
VITE_API_URL=https://api.your-domain.com

# --- Stripe (https://dashboard.stripe.com/apikeys) ---
STRIPE_SECRET_KEY=sk_live_or_test_...
# From your Stripe webhook endpoint settings — see DEPLOYMENT.md for setup steps
STRIPE_WEBHOOK_SECRET=whsec_...

# --- OpenAI (https://platform.openai.com/api-keys) ---
OPENAI_API_KEY=sk-...

# --- Email (any SMTP provider, e.g. SendGrid, Postmark, Gmail app password) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Cloudinary (https://cloudinary.com/console) for image uploads ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
